<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.modules.category.mapper.CategoryMapper">

    <resultMap id="BaseResultMap" type="com.blog.modules.category.domain.entity.Category">
        <id property="id" column="id"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleted" column="deleted"/>
        <result property="version" column="version"/>
        <result property="name" column="name"/>
        <result property="sort" column="sort"/>
        <result property="description" column="description"/>
        <result property="articleCount" column="article_count"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,create_by,update_by,create_time,update_time,deleted,
        version,name,sort,`description`
    </sql>

    <select id="selectListWithArticleCount" resultMap="BaseResultMap">
        SELECT c.*,
               IFNULL(ac.article_count, 0) AS article_count
        FROM t_category c
                 LEFT JOIN (
            SELECT category_id,
                   COUNT(1) AS article_count
            FROM t_article
            WHERE category_id IS NOT NULL
              AND status = '1'
              AND deleted = 0
            GROUP BY category_id
        ) ac ON ac.category_id = c.id
        WHERE c.deleted = 0
        ORDER BY c.sort ASC, c.id ASC
    </select>
</mapper>
